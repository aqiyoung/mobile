# Copy this file to .env and fill in real values. .env is gitignored.
# These mirror the GitHub Actions secrets used by .github/workflows/*-release.yml,
# so the same names work in CI and locally.
#
# File-path values are resolved relative to the repo root. The recommended
# layout is to drop credential files into the gitignored .credentials/
# directory and reference them as below.

# ---- Apple / iOS ----

# Apple Distribution certificate (.p12) and its password.
# In CI this is base64-encoded into APPLE_DISTRIBUTION_CERTIFICATE; locally we
# point at the file directly to avoid round-tripping through base64.
APPLE_DISTRIBUTION_CERTIFICATE_P12_PATH=.credentials/distribution.p12
APPLE_DISTRIBUTION_CERTIFICATE_PASSWORD=

# Apple Developer team ID (10-character).
APPLE_TEAM_ID=

# App Store Connect API key (.p8), its key ID, and issuer ID.
APP_STORE_CONNECT_API_KEY_PATH=.credentials/AuthKey_XXXXXXXXXX.p8
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=

# App Store distribution provisioning profile (.mobileprovision).
APP_STORE_PROVISIONING_PROFILE_PATH=.credentials/AppStore.mobileprovision

# Password used to create a temporary build keychain. Pick anything.
KEYCHAIN_PASSWORD=local-build-keychain-password

# ---- Android / Google Play ----

# Upload keystore (.jks).
ANDROID_SIGNING_KEY_PATH=.credentials/upload-keystore.jks
ANDROID_KEY_STORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Optional: Google Play service account JSON. If unset, scripts skip
# the Play upload step (same behavior as CI).
PLAY_SERVICE_ACCOUNT_JSON_PATH=
